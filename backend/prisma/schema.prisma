
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String
  handle    String   @unique
  email     String   @unique
  password  String

  avatar    String?
  bio       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
} 